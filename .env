# ─────────────────────────────────────────────────────────────
# 프론트엔드 환경변수 — 단일 소스 (커밋됨)
# 코드에서는 process.env 대신 src/lib/env.ts 를 통해 소비한다.
#
# 주의:
#  - NEXT_PUBLIC_* 는 빌드 시점에 번들로 인라인됨 → 값 변경 후 dev 서버 재시작(배포는 redeploy) 필요.
#  - 여기엔 공개값만 둔다. client_secret / JWT_SECRET 같은 시크릿은 절대 프론트에 두지 않는다(백엔드 전용).
#    code 교환은 백엔드(POST /api/v1/auth/google)가 client_secret 으로 수행한다.
#  - 배포(Vercel)에서는 대시보드 환경변수가 이 파일 값을 override 한다(프로덕션 값은 Vercel에서 관리).
# ─────────────────────────────────────────────────────────────

# 백엔드 API base (끝에 / 없이). prod: https://be-production-5944.up.railway.app
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Google OAuth client_id (공개값 — 동의 화면 URL 생성에 사용). 백엔드 GOOGLE_CLIENT_ID 와 동일.
# 비우면 googleSignInAction 이 mock 로그인으로 폴백한다(실 구글/백엔드 미연동).
NEXT_PUBLIC_GOOGLE_CLIENT_ID=412556665535-fv4p9f8jj9k2j8jafiisg6k1l3jt2siq.apps.googleusercontent.com

# 구글 동의 화면 redirect_uri. 백엔드 GOOGLE_REDIRECT_URI · Google Console 승인 URI 와 반드시 동일.
# FE 콜백 경로는 /auth/callback. 미설정 시 ${NEXT_PUBLIC_APP_URL}/auth/callback 로 구성.
NEXT_PUBLIC_GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

# 프론트 자기 도메인 (redirect_uri 폴백 구성 등). prod: https://<프론트도메인>
NEXT_PUBLIC_APP_URL=http://localhost:3000

# "true"면 src/lib/mocks 사용. 실 백엔드 데이터 연동 시 false.
NEXT_PUBLIC_USE_MOCK=false
