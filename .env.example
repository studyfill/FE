# ─────────────────────────────────────────────────────────────
# 프론트엔드 전용 환경변수
# 주의: NEXT_PUBLIC_* 는 빌드 시점에 번들에 인라인됨 → Vercel 환경변수 변경 후 redeploy 필요.
# 주의: client_secret / JWT_SECRET 같은 시크릿은 절대 프론트에 두지 않는다(백엔드 전용).
#       code 교환은 백엔드(POST /api/v1/auth/google)가 client_secret 으로 수행한다.
# ─────────────────────────────────────────────────────────────

# 백엔드 API (Railway). 끝에 / 없이.
# prod: https://be-production-5944.up.railway.app
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Google OAuth client_id (공개값 — 동의 화면 URL 생성에 사용). 백엔드 GOOGLE_CLIENT_ID 와 동일.
# 미설정 시 mock 로그인으로 폴백한다.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# 구글 동의 화면 redirect_uri. 백엔드 GOOGLE_REDIRECT_URI · Google Console 승인 URI 와 반드시 동일.
# FE 콜백 경로는 /auth/callback 이다.
# prod 예: https://<프론트도메인>/auth/callback
# 미설정 시 ${NEXT_PUBLIC_APP_URL}/auth/callback 로 구성됨.
NEXT_PUBLIC_GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

# 프론트 자기 도메인 (redirect_uri 폴백 구성 등). prod: https://<프론트도메인>
NEXT_PUBLIC_APP_URL=http://localhost:3000

# mock 토글: "true"면 src/lib/mocks 사용. 실제 백엔드 데이터 연동 시 false(또는 미설정).
NEXT_PUBLIC_USE_MOCK=true
